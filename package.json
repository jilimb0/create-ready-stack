{
  "name": "create-ready-stack",
  "version": "0.3.0",
  "description": "Scaffold a production-ready monorepo with your proven stack: Hono 4 + Drizzle ORM + React 19 + TanStack Query 5 + TGWrapper bot",
  "type": "module",
  "files": [
    "dist/",
    "bin/"
  ],
  "main": "dist/cli.js",
  "bin": {
    "create-ready-stack": "bin/create-ready-stack.mjs"
  },
  "scripts": {
    "build": "tsc",
    "start": "node bin/create-ready-stack.mjs init",
    "dev": "pnpm build --watch",
    "lint": "biome lint src/",
    "lint:fix": "biome check --write src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:bench": "vitest run tests/benchmark.test.ts --coverage.enabled=false",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "validate": "pnpm check && pnpm build",
    "prepublishOnly": "pnpm validate"
  },
  "keywords": [
    "cli",
    "scaffold",
    "hono",
    "drizzle",
    "react",
    "tanstack-query",
    "telegram-bot"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/jilimb0/create-ready-stack"
  },
  "author": "Maksym Opanasenko",
  "license": "MIT",
  "dependencies": {
    "fs-extra": "^11.2.0",
    "inquirer": "^12.3.2",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.0",
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^9.0.7",
    "@types/node": "^22.10.2",
    "@types/yargs": "^17.0.33",
    "@vitest/coverage-v8": "^4.1.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
