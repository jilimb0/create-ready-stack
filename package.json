{
  "name": "create-ready-stack",
  "version": "0.1.0",
  "description": "Scaffold a production-ready monorepo with your proven stack: Hono 4 + Drizzle ORM + React 19 + TanStack Query 5 + TGWrapper bot",
  "type": "module",
  "files": [
    "dist/",
    "bin/",
    "templates/"
  ],
  "main": "dist/cli.js",
  "bin": {
    "create-ready-stack": "./bin/create-ready-stack.mjs"
  },
  "scripts": {
    "build": "tsc",
    "start": "node bin/create-ready-stack.mjs init",
    "dev": "pnpm build --watch",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "cli",
    "scaffold",
    "hono",
    "drizzle",
    "react",
    "tanstack-query",
    "telegram-bot"
  ],
  "author": "Maksym Opanasenko",
  "license": "MIT",
  "dependencies": {
    "inquirer": "^12.3.2",
    "yargs": "^17.7.2",
    "fs-extra": "^11.2.0",
    "ejs": "^3.1.10"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/inquirer": "^9.0.7",
    "@types/yargs": "^17.0.33",
    "@types/fs-extra": "^11.0.4",
    "@types/ejs": "^3.1.5",
    "typescript": "^5.7.2",
    "ts-node": "^10.9.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
