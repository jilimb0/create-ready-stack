// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`generated output snapshots > CI workflow matches snapshot > ci-workflow 1`] = `
"name: CI

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

jobs:
  validate:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: pnpm/action-setup@v4
      - uses: actions/setup-node@v4
        with: { node-version: 26, cache: pnpm }
      - run: pnpm install --frozen-lockfile
      - run: pnpm check

  test:
    runs-on: ubuntu-latest
    services:
      postgres:
        image: postgres:16-alpine
        env:
          POSTGRES_USER: postgres
          POSTGRES_PASSWORD: postgres
          POSTGRES_DB: snapshot-test
        options: >-
          --health-cmd pg_isready
          --health-interval 10s
          --health-timeout 5s
          --health-retries 5
        ports: [5432:5432]
    steps:
      - uses: actions/checkout@v4
      - uses: pnpm/action-setup@v4
      - uses: actions/setup-node@v4
        with: { node-version: 26, cache: pnpm }
      - run: pnpm install --frozen-lockfile
      - run: pnpm test
        env:
          DATABASE_URL: postgresql://postgres:postgres@localhost:5432/snapshot-test
"
`;

exports[`generated output snapshots > docker-compose.yml matches snapshot > docker-compose 1`] = `
{
  "services": {
    "backend": {
      "build": {
        "context": "./backend",
        "dockerfile": "./Dockerfile",
      },
      "depends_on": {
        "db": {
          "condition": "service_healthy",
        },
      },
      "environment": {
        "DATABASE_URL": "postgresql://\${POSTGRES_USER:-postgres}:\${POSTGRES_PASSWORD:-postgres}@db:5432/\${POSTGRES_DB:-snapshot-test}",
        "NODE_ENV": "production",
      },
      "healthcheck": {
        "interval": "30s",
        "retries": 3,
        "start_period": "10s",
        "test": [
          "CMD",
          "wget",
          "--no-verbose",
          "--tries=1",
          "--spider",
          "http://localhost:3000/health",
        ],
        "timeout": "10s",
      },
      "ports": [
        "3000:3000",
      ],
      "restart": "unless-stopped",
    },
    "bot": {
      "build": {
        "context": "./bot",
        "dockerfile": "./Dockerfile",
      },
      "depends_on": {
        "backend": {
          "condition": "service_started",
        },
      },
      "environment": {
        "NODE_ENV": "production",
        "TELEGRAM_TOKEN": "\${TELEGRAM_TOKEN}",
      },
      "restart": "unless-stopped",
    },
    "db": {
      "environment": {
        "POSTGRES_DB": "\${POSTGRES_DB:-snapshot-test}",
        "POSTGRES_PASSWORD": "\${POSTGRES_PASSWORD:-postgres}",
        "POSTGRES_USER": "\${POSTGRES_USER:-postgres}",
      },
      "healthcheck": {
        "interval": "10s",
        "retries": 5,
        "test": [
          "CMD-SHELL",
          "pg_isready -U \${POSTGRES_USER:-postgres}",
        ],
        "timeout": "5s",
      },
      "image": "postgres:16-alpine",
      "ports": [
        "5432:5432",
      ],
      "restart": "unless-stopped",
      "volumes": [
        "postgres_data:/var/lib/postgresql/data",
      ],
    },
    "web": {
      "build": {
        "context": "./web",
        "dockerfile": "./Dockerfile",
      },
      "depends_on": {
        "backend": {
          "condition": "service_started",
        },
      },
      "environment": {
        "NODE_ENV": "production",
      },
      "ports": [
        "5173:80",
      ],
      "restart": "unless-stopped",
    },
  },
  "volumes": {
    "postgres_data": {},
  },
}
`;

